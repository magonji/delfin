 # Database files - NEVER upload to GitHub
data/*.db
data/*.db-wal
data/*.db-shm
data/*.sqlite
data/*.sqlite3

# Runtime backups (created by the daily off-disk backup)
backups/

# Encryption keyfile, session secret and runtime state — never commit these
data/.delfin_keyfile.json
data/.delfin_session_secret
data/.maintenance_state
data/maintenance_settings.json

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environment (por si lo usas en el futuro)
venv/
env/
ENV/

# Not needed
.claude/

# iconos
*.afdesign

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# executable files
*.bat
*.command

# Environment variables (para contraseñas en el futuro)
.env
